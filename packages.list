
[
   package {
      name = "neovim";
      description = "Chad editor";
      setup_command = "./neovim.sh";
      dependencies = [
	 package {
	    name = "fd";
	    description = "\"find\" alternative";
	 },
	 package {
	    name ="ripgrep";
	    description = "\"grep\" alternative";
	 },
	 package { // This could be transferred to hyprland dependency
	    name = "wl-clipboard";
	    description = "wayland clipboard support";
	 }
      ];
   },
