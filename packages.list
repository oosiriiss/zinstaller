
[
   package {
      name = "hyprland"
      description = "hyprland yeah";
      setup_command = "./wayland.sh"
      dependencies = [
	 "egl-wayland",
	 "wlr-randr",
	 # Qt isnt technically ad ependency 
	 "qt5-wayland",
	 "qt6-wayland",
      ]
   },
   package {
      name = "hyprpaper"
      description = "wallpaper with hyprland";

   },
   package {
      name = "zsh";
      description = "shell"
      setup_command = "./zsh.sh"
      dependencies = [
	 "zsh-completions"
      ]
   },
   package {
      name = "waybar"
      description = "top bar"
   },
   //package {
   //   name = "rofi-lbonn-wayland-git"
   //   description = "rofi for wayland? but id if maybe there are some better ports"
   //},
   package {
      name = "swaync"
      description = "notification daemon"
   },
   package {
      name = "nautilus"
      description = "file manager (picker?)"
   },	
   package {
      name = "sddm"
      description = "Login manager"
      setup_command = "./login_manager.sh"
   },
   package {
      name="alacritty"
      description = "terminal emulator"
   }
   package {
      name = "neovim"
      description = "Chad editor"
      setup_command = "./neovim.sh"
      dependencies = [
	 package {
	    name = "fd";
	    description = "\"find\" alternative"
	 },
	 package {
	    name ="ripgrep"
	    description = "\"grep\" alternative"
	 },
	 package { // This could be transferred to hyprland dependency
	    name = "wl-clipboard"
	    description = "wayland clipboard support"
	 }
      ];
   },
   package {
      // Git should already be installed on the system but the script sets some config stuff
      name = "git"
      description = "version control system"
      setup_command = "./git.sh"
   },
   package {
      name = "pulseaudio"
      description = "General purpose sound server, middleware between apps and hardware"
   },
   package {
      // AUR package
      name = "supergfxctl"
      description = "GPU Switching on hybrid laptop"
      setup_command = "sudo systemctl enable supergfxd"
   },
   package {
      // AUR package
      name = "asusctl"
      description = "Asus laptop utils, charge limit, power plans, fan speeds etc."
      setup_command = "asusctl --chg-limit 80"
   },
   package {
      name = "nvidia-open"
      description = "Nvidia open source kernel modules. Recommended for card newer than NV160 family (Turing)."
      setup_command = "./nvidia.sh"
      dependencies = [
	 // I guess thi sautomatically sets the modeset and fbdev?
	 "nvidia-utils",
	 // hardware video acceleration driver
	 "liba-nvidia-driver",
      ]
   }
   
]



